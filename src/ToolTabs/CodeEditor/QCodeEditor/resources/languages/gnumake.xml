<?xml version="1.0" encoding="UTF-8" ?>
<root>
    <!-- Комментарии -->
    <section name="Comment">
        <pattern>#.*</pattern>
    </section>

    <!-- Переменные (определение: VAR = ...) -->
    <section name="Variable">
        <pattern>\b[A-Z_][A-Z0-9_]*\s*(?=[+?:]?=)</pattern>
    </section>

    <!-- Использование переменных ($(VAR) или $@) -->
    <section name="VariableUsage">
        <pattern>\$\([A-Z_][A-Z0-9_]*\)</pattern>
        <pattern>\$\{[A-Z_][A-Z0-9_]*\}</pattern>
        <pattern>\$[@%&lt;?^|*]</pattern> <!-- Автоматические переменные $@, $< и т.д. -->
    </section>

    <!-- Таргеты (все что перед двоеточием в начале строки) -->
    <section name="Target">
        <pattern>^[a-zA-Z0-9._/-]+(?=\s*:)</pattern>
    </section>

    <!-- Директивы -->
    <section name="Directive">
        <name>include</name>
        <name>-include</name>
        <name>ifdef</name>
        <name>ifndef</name>
        <name>else</name>
        <name>endif</name>
        <name>ifeq</name>
        <name>ifneq</name>
        <name>define</name>
        <name>endef</name>
        <name>override</name>
        <name>export</name>
        <name>unexport</name>
        <name>vpath</name>
    </section>

    <!-- Встроенные функции -->
    <section name="BuiltinFunction">
        <name>subst</name>
        <name>patsubst</name>
        <name>strip</name>
        <name>findstring</name>
        <name>filter</name>
        <name>filter-out</name>
        <name>sort</name>
        <name>word</name>
        <name>wordlist</name>
        <name>words</name>
        <name>firstword</name>
        <name>lastword</name>
        <name>dir</name>
        <name>notdir</name>
        <name>suffix</name>
        <name>basename</name>
        <name>addsuffix</name>
        <name>addprefix</name>
        <name>join</name>
        <name>wildcard</name>
        <name>realpath</name>
        <name>abspath</name>
        <name>error</name>
        <name>warning</name>
        <name>shell</name>
        <name>origin</name>
        <name>flavor</name>
        <name>foreach</name>
        <name>if</name>
        <name>or</name>
        <name>and</name>
        <name>call</name>
        <name>eval</name>
        <name>value</name>
        <name>file</name>
    </section>

    <!-- Специальные цели -->
    <section name="SpecialTarget">
        <name>.PHONY</name>
        <name>.SUFFIXES</name>
        <name>.DEFAULT</name>
        <name>.PRECIOUS</name>
        <name>.INTERMEDIATE</name>
        <name>.SECONDARY</name>
        <name>.SECONDEXPANSION</name>
        <name>.DELETE_ON_ERROR</name>
        <name>.IGNORE</name>
        <name>.LOW_RESOLUTION_TIME</name>
        <name>.SILENT</name>
        <name>.EXPORT_ALL_VARIABLES</name>
        <name>.NOTPARALLEL</name>
        <name>.ONESHELL</name>
        <name>.POSIX</name>
    </section>
</root>